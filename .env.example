# Local development uses server/data/store.json when DATABASE_URL is omitted.
DATABASE_URL=postgresql://username:password@localhost:5432/noted
PORT=3001
NODE_ENV=development

# Gmail SMTP: enable 2-Step Verification and create a Google App Password.
GMAIL_USER=youraccount@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password
WELCOME_FROM_EMAIL=Noted <youraccount@gmail.com>
