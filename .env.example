# Local development uses server/data/store.json when DATABASE_URL is omitted.
DATABASE_URL=postgresql://username:password@localhost:5432/noted
PORT=3001
NODE_ENV=development

# Create an API key at https://resend.com and verify your sending domain.
RESEND_API_KEY=re_your_api_key
WELCOME_FROM_EMAIL=Noted <welcome@yourdomain.com>
